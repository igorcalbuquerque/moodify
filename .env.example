# --- AI provider (swappable) ---
# Which LLM backend builds the playlist plan: anthropic | openai | ollama
AI_PROVIDER=anthropic

# --- Anthropic (Claude) ---  [used when AI_PROVIDER=anthropic]
# Preferred: browser login — run `ant auth login` (opens a browser, no key here).
# The SDK picks up that profile automatically; leave ANTHROPIC_API_KEY unset.
# Alternative: paste an API key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI-compatible --- [used when AI_PROVIDER=openai]
# Works with OpenAI and compatible gateways (Azure, Together, Groq, OpenRouter, ...)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama (local) --- [used when AI_PROVIDER=ollama]
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1

# --- Spotify ---
# Create an app at https://developer.spotify.com/dashboard,
# then register the Redirect URI below in the app settings.
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Must match EXACTLY one of the Redirect URIs registered in your Spotify app.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# Public base URL of the app (used for post-auth redirects + cookie security).
BASE_URL=http://127.0.0.1:3000

# Port Bun.serve listens on.
PORT=3000

# Setup lock: once configured, the in-browser setup screen is locked so visitors
# can't overwrite your config. Set a token here to allow re-configuration from
# the browser (sent as the x-setup-token header); otherwise edit .moodify.json.
# MOODIFY_SETUP_TOKEN=

# --- Sharing on your local network (optional) ---
# Spotify only allows http redirect URIs for loopback (127.0.0.1), so sharing
# to other devices requires HTTPS. Provide a cert/key (e.g. via mkcert) and set
# BASE_URL + SPOTIFY_REDIRECT_URI to your machine's LAN IP. Then register that
# same redirect URI in the Spotify dashboard. Example:
#   BASE_URL=https://192.168.0.42:3000
#   SPOTIFY_REDIRECT_URI=https://192.168.0.42:3000/api/auth/callback
#   SSL_CERT_FILE=./certs/cert.pem
#   SSL_KEY_FILE=./certs/key.pem
# SSL_CERT_FILE=
# SSL_KEY_FILE=
# HOST=0.0.0.0
